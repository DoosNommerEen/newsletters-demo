# Tavily API — https://app.tavily.com
# Free tier: 1,000 API calls/month
TAVILY_API_KEY=tvly-YOUR_API_KEY_HERE

# Anthropic API — https://console.anthropic.com
# Pay-per-token; fund your account before running
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Gamma API — https://gamma.app > Settings > API Key
# Requires a Gamma Pro account (~150 credits per presentation)
GAMMA_API_KEY=sk-gamma-YOUR_KEY_HERE

# Resend API — https://resend.com
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# Sender address — must use a domain verified in Resend dashboard
# Format: "Display Name <you@yourdomain.com>"
# Omit to use Resend's test sender (can only send to your own account email)
RESEND_FROM=AI Newsletter <newsletter@yourdomain.com>

# Comma-separated list of recipient email addresses
NEWSLETTER_RECIPIENTS=recipient@example.com,another@example.com
